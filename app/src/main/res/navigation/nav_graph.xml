<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.coursesapp.feature.login.LoginFragment"
        android:label="Вход"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.coursesapp.feature.main.MainFragment"
        android:label="@string/tab_home"
        tools:layout="@layout/fragment_main" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.coursesapp.feature.favorites.FavoritesFragment"
        android:label="@string/tab_favorites"
        tools:layout="@layout/fragment_favorites" />

    <fragment
        android:id="@+id/accountFragment"
        android:name="com.example.coursesapp.feature.account.AccountFragment"
        android:label="@string/tab_account"
        tools:layout="@layout/fragment_account" />

</navigation>
